# Использует переменные окружения DOMAIN/EMAIL из docker-compose
{$DOMAIN} {
	encode zstd gzip

	# Агрессивное кеширование для статики Next
	@static path /_next/static/* /favicon.ico /robots.txt /sitemap.xml /images/* /public/*
	handle @static {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy app:3000
	}

	# Всё остальное — в Next
	reverse_proxy app:3000

	# Базовые заголовки безопасности
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer-when-downgrade"
	}
	# Авто TLS: для локалки с DOMAIN=localhost Caddy сам будет без TLS, для домена — LE.
	# Можно принудительно включить локальный TLS:
	# tls internal
}
