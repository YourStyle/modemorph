# Использует переменные окружения DOMAIN/EMAIL из docker-compose
{$DOMAIN} {
	encode zstd gzip

	# Агрессивное кеширование для статики Next
	@static path /_next/static/* /favicon.ico /robots.txt /sitemap.xml /images/* *.svg *.png *.jpg *.webp *.ico *.woff2
	handle @static {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy app:3000
	}

	# ALL /api/* requests go to FastAPI backend
	handle /api/* {
		reverse_proxy backend:8080
	}

	# Health check for backend (direct access)
	handle /backend/* {
		uri strip_prefix /backend
		reverse_proxy backend:8080
	}

	# Everything else — Next.js frontend
	reverse_proxy app:3000

	# Базовые заголовки безопасности
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "frame-ancestors 'self' https://web.telegram.org https://*.telegram.org"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer-when-downgrade"
		-X-Frame-Options
	}
}
