# ModeMorph Backend Environment Variables

# Database (auto-configured in Docker, override for local dev)
DATABASE_URL=postgresql+asyncpg://modemorph:modemorph@localhost:5433/modemorph

# JWT (use the same secret as Supabase for migration compatibility)
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_PEPPER=your-pepper

# Yandex ID OAuth (login) — distinct from the Yandex S3 keys below
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# Public frontend origin — used to build OAuth redirect_uri (e.g. https://modemorph.ru/auth/yandex/callback)
FRONTEND_URL=https://modemorph.ru

# N8N — only for AI API calls that need foreign server
N8N_BASE_URL=https://modemorph.up.railway.app/webhook

# AI Service (CLIP/FAISS, internal)
AI_SERVICE_URL=http://modemorph-ai:8000

# Yandex S3
YANDEX_S3_ACCESS_KEY_ID=
YANDEX_S3_SECRET_ACCESS_KEY=
YANDEX_S3_BUCKET_NAME=modemorphs3

# Robokassa
ROBOKASSA_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=

# OpenWeather
OPENWEATHER_API_KEY=
