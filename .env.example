# ModeMorph Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Supabase Configuration
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# AI Service Configuration
# ============================================
# URL of your Python AI service deployed on Railway
NEXT_PUBLIC_AI_API_URL=https://your-ai-service.up.railway.app/webhook

# ============================================
# Yandex Object Storage (S3-compatible)
# ============================================
# Get these from: https://console.cloud.yandex.ru/
YANDEX_S3_ACCESS_KEY_ID=YCAJE...
YANDEX_S3_SECRET_ACCESS_KEY=YCO...
YANDEX_S3_BUCKET_NAME=modemorphs3
YANDEX_S3_REGION=ru-central1
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net

# ============================================
# Telegram Mini App (Optional for development)
# ============================================
# Mock Telegram init data for local testing
# Remove or comment out in production
# NEXT_PUBLIC_TG_MOCK_INIT_DATA=query_id=...

# ============================================
# Caddy Configuration (for Docker deployment)
# ============================================
# Your domain name (use 'localhost' for local development)
DOMAIN=your-domain.com
# Email for Let's Encrypt SSL certificates
CADDY_EMAIL=admin@your-domain.com

# ============================================
# Node Environment
# ============================================
NODE_ENV=production

# ============================================
# Error Tracking (Sentry)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
